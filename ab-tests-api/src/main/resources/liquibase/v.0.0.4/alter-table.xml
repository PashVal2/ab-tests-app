<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">

    <changeSet id="alter-api-keys-add-created-at" author="valdon">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="api_keys" columnName="created_at"/>
            </not>
        </preConditions>

        <addColumn tableName="api_keys">
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="alter-user-events-add-created-at" author="valdon">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="user_events" columnName="created_at"/>
            </not>
        </preConditions>

        <addColumn tableName="user_events">
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>