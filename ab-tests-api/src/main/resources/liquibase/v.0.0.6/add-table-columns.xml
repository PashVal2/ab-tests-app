<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">

    <changeSet id="metric-results-rename-sample-size-to-assigned-users-v006" author="valdon">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="metric_results"/>
                <columnExists tableName="metric_results" columnName="sample_size"/>
                <not>
                    <columnExists tableName="metric_results" columnName="assigned_users"/>
                </not>
            </and>
        </preConditions>

        <renameColumn
                tableName="metric_results"
                oldColumnName="sample_size"
                newColumnName="assigned_users"
                columnDataType="bigint"/>
    </changeSet>

    <changeSet id="metric-results-add-assigned-users-v006" author="valdon">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="metric_results"/>
                <not>
                    <columnExists tableName="metric_results" columnName="assigned_users"/>
                </not>
            </and>
        </preConditions>

        <addColumn tableName="metric_results">
            <column name="assigned_users" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

